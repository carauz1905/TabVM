{
  "$meta": {
    "name": "TabVM Design Tokens",
    "concept": "The tab-panel: a running VM living inside a browser tab.",
    "version": "1.0.0"
  },
  "color": {
    "neutral": {
      "950": "#0B0E13",
      "900": "#0E1116",
      "800": "#161B22",
      "700": "#21262D",
      "600": "#30363D",
      "500": "#6E7681",
      "400": "#8B949E",
      "300": "#C9D1D9",
      "200": "#DCE3EA",
      "100": "#F0F3F6",
      "050": "#F7F9FB",
      "000": "#FFFFFF"
    },
    "signal": {
      "700": "#0B7C6F",
      "600": "#0E9E8E",
      "500": "#14B8A6",
      "400": "#2FE3CE",
      "300": "#7DF0E0"
    }
  },
  "theme": {
    "light": {
      "bg": "#FFFFFF",
      "surface": "#F7F9FB",
      "surfaceAlt": "#F0F3F6",
      "text": "#0E1116",
      "muted": "#6E7681",
      "border": "#DCE3EA",
      "accent": "#0E9E8E",
      "mark": "#0E1116",
      "onAccent": "#FFFFFF"
    },
    "dark": {
      "bg": "#0E1116",
      "surface": "#161B22",
      "surfaceAlt": "#21262D",
      "text": "#F0F3F6",
      "muted": "#8B949E",
      "border": "#21262D",
      "accent": "#2FE3CE",
      "mark": "#E6EDF3",
      "onAccent": "#07110F"
    }
  },
  "font": {
    "display": "'Space Grotesk', 'Segoe UI', system-ui, -apple-system, sans-serif",
    "body": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "mono": "'JetBrains Mono', 'Space Mono', ui-monospace, 'Cascadia Code', Consolas, monospace"
  },
  "radius": { "sm": "4px", "md": "8px", "lg": "12px", "pill": "999px" },
  "motion": {
    "caretBlink": "1.05s",
    "assemble": "0.6s",
    "easing": "cubic-bezier(0.2, 0.7, 0.2, 1)"
  }
}
